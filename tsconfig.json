{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "lib": [
      "ES2022"
    ]
  },
  "include": [
    "src/**/*.ts",
    "echo-pdf.config.json"
  ]
}
